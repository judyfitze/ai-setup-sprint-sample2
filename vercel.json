{
  "version": 2,
  "cleanUrls": true,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/inquiry",
      "destination": "/api/inquiry.js"
    },
    {
      "source": "/api/stripe-webhook",
      "destination": "/api/stripe-webhook.js"
    }
  ]
}